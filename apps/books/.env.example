# Books App — copy to .env.local for local development overrides

# Backend API / Strapi URL (required)
NEXT_PUBLIC_API_URL=http://localhost:1337
# NEXT_PUBLIC_STRAPI_URL=http://localhost:1337  # alias, falls back to NEXT_PUBLIC_API_URL

# Supabase (required for auth + real-time features)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Production (set in Vercel Project Environment Variables)
# NEXT_PUBLIC_API_URL=https://api.webfudge.in
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
