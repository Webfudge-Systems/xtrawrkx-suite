# PM App — copy to .env.local for local development overrides

# Backend API (required)
NEXT_PUBLIC_API_URL=http://localhost:1337

# CRM app URL — used for "Open in CRM" cross-app links
NEXT_PUBLIC_CRM_APP_URL=http://localhost:3001

# Public URL of this app — drives metadataBase / OG URLs (required for production)
NEXT_PUBLIC_PM_APP_URL=http://localhost:3006

# Production (set in Vercel Project Environment Variables)
# NEXT_PUBLIC_API_URL=https://api.webfudge.in
# NEXT_PUBLIC_CRM_APP_URL=https://crm.webfudge.in
# NEXT_PUBLIC_PM_APP_URL=https://pm.webfudge.in
