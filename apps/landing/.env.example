FIREBASE_ADMIN_PASSWORD=password1234
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
NEXT_PUBLIC_USE_CMS_DATA=true

NEXT_PUBLIC_CRM_PORTAL_URL=https://crm.xtrawrkx.com
