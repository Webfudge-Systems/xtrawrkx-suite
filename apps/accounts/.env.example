# Accounts app — copy to .env.local for local overrides

# Backend API (required for production builds)
NEXT_PUBLIC_API_URL=http://localhost:1337

# Public URL of this app — drives metadataBase / OG URLs (required for production)
NEXT_PUBLIC_ACCOUNTS_APP_URL=http://localhost:3003

# CRM origin for “Open in CRM” links on Audit Logs (optional locally)
# NEXT_PUBLIC_CRM_ORIGIN=http://localhost:3001

# Optional
# NEXT_PUBLIC_TRIAL_DAYS_REMAINING=12
