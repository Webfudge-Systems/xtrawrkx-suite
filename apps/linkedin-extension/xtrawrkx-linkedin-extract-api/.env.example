PORT=3847
NODE_ENV=development

# anthropic | openai
AI_PROVIDER=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Max raw HTML bytes accepted (default 2_500_000)
MAX_HTML_BYTES=2500000

# Max bytes after cleaning sent to the model (default 400_000)
MAX_CLEANED_BYTES=400000

# Additional cap: estimated input tokens for HTML inside the user prompt (default 28000)
AI_MAX_ESTIMATED_INPUT_TOKENS=28000

# Optional: require Authorization: Bearer <token>
EXTRACT_API_SECRET=

# Debug raw HTML dumps (default ./storage/debug)
DEBUG_HTML_DIR=./storage/debug

# Retain at most N debug files (0 = no limit, default 50)
DEBUG_HTML_MAX_FILES=50

# --- Profile enrichment (web search + second AI merge) ---
PROFILE_ENRICHMENT_ENABLED=true

# auto | serpapi | google | none
SEARCH_PROVIDER=auto
SERPAPI_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
WEB_SEARCH_NUM_RESULTS=10
