# Copy to .env for local Strapi against Railway production Postgres.
# Never commit .env (gitignored).

HOST=0.0.0.0
PORT=1337
NODE_ENV=development

DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/railway
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=5

SEED_DATA=false
PLATFORM_ADMIN_RESET_PASSWORD=false
REDIS_ENABLED=false
CACHE_API_ENABLED=false

PUBLIC_URL=https://xtrawrkxsuits-production.up.railway.app

# Copy APP_KEYS, JWT_SECRET, etc. from Railway API service variables if you need
# tokens issued by production to validate locally (optional).
