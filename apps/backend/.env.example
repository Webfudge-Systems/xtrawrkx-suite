HOST=0.0.0.0
PORT=1337

NODE_ENV=production
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://user:password@host:port/railway
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=5
SEED_DATA=false

PUBLIC_URL=https://api.xtrawrkx.com

APP_KEYS=key1,key2,key3,key4
ADMIN_JWT_SECRET=generate-me
API_TOKEN_SALT=generate-me
TRANSFER_TOKEN_SALT=generate-me
JWT_SECRET=generate-me
ENCRYPTION_KEY=generate-me

REDIS_URL=redis://default:password@host:6379
REDIS_ENABLED=true
CACHE_API_ENABLED=true
CACHE_TTL_SECONDS=300

PLATFORM_ADMIN_EMAIL=admin@xtrawrkx.com
PLATFORM_ADMIN_PASSWORD=change-me
PLATFORM_ADMIN_RESET_PASSWORD=false

LANDING_APP_URL=https://xtrawrkx.com
CRM_APP_URL=https://crm.xtrawrkx.com
PM_APP_URL=https://pm.xtrawrkx.com
ACCOUNTS_APP_URL=https://base.xtrawrkx.com
