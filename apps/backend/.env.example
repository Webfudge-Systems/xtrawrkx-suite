HOST=0.0.0.0
PORT=1337

# Default: SQLite local. For Railway prod Postgres locally, see .env.production-local.example

NODE_ENV=production
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://user:password@host:port/railway
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=5
SEED_DATA=false

PUBLIC_URL=https://xtrawrkxsuits-production.up.railway.app

APP_KEYS=key1,key2,key3,key4
ADMIN_JWT_SECRET=generate-me
API_TOKEN_SALT=generate-me
TRANSFER_TOKEN_SALT=generate-me
JWT_SECRET=generate-me
ENCRYPTION_KEY=generate-me

REDIS_URL=redis://default:password@host:6379
REDIS_ENABLED=true
CACHE_API_ENABLED=true
CACHE_TTL_SECONDS=300

PLATFORM_ADMIN_EMAIL=admin@xtrawrkx.com
PLATFORM_ADMIN_PASSWORD=change-me
PLATFORM_ADMIN_RESET_PASSWORD=false

LANDING_APP_URL=https://xtrawrkx.com
# Shared secret for landing → Strapi website signup (client account in CRM)
LANDING_SIGNUP_SECRET=generate-me
# Organization id for website signups (default: auto-detect Xtrawrkx org)
WEBSITE_SIGNUP_ORG_ID=1
CRM_APP_URL=https://crm.xtrawrkx.com
PM_APP_URL=https://pm.xtrawrkx.com
ACCOUNTS_APP_URL=https://accounts.xtrawrkx.com
# Optional comma-separated extra CORS origins (e.g. preview URLs)
# CORS_EXTRA_ORIGINS=https://preview.example.com
