HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# ─── Database ───────────────────────────────────────────────────────────────
# SQLite (default — development only, NOT suitable for production SAAS)
DATABASE_CLIENT=sqlite

# PostgreSQL (recommended for production / multi-tenant SAAS)
# 1. Install the driver:  npm install pg  (in apps/backend)
# 2. Set DATABASE_CLIENT=postgres  and fill in the vars below.
# DATABASE_CLIENT=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=webfudge_platform
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=your_strong_password
# DATABASE_SSL=false
# Remote Postgres (e.g. Supabase): if Node errors on TLS chain, set DATABASE_SSL=true and try:
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# (Prefer fixing CA trust / NODE_EXTRA_CA_CERTS in production.)
# DATABASE_SCHEMA=public
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10
# Or use a full connection string (e.g. on Supabase / Railway / Neon):
# DATABASE_URL=postgresql://postgres:password@db.host:5432/webfudge_platform
#
# Railway (link Postgres service → API service variables):
# DATABASE_CLIENT=postgres
# DATABASE_URL=${{Postgres.DATABASE_PRIVATE_URL}}
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# DATABASE_POOL_MIN=0
# DATABASE_POOL_MAX=5
# SEED_DATA=false
# See docs/RAILWAY_STRAPI_DEPLOY.md

# ─── Seed data ──────────────────────────────────────────────────────────────
# Default apps (CRM, PM, Accounts) + modules seed automatically when the DB has
# no App entries. Set SEED_DATA=true to run the seed again (updates by slug).
# SEED_DATA=true

# ─── Redis (optional caching) ───────────────────────────────────────────────
# Railway: link Redis service → API variables get REDIS_URL automatically.
# Private URL (API ↔ Redis in same project): redis://default:pass@redis.railway.internal:6379
# Local dev: use Redis → Connect → public URL (internal host does not resolve on your PC).
# REDIS_URL=redis://default:password@switchback.proxy.rlwy.net:31548
# Or omit REDIS_URL and use Railway-injected REDISHOST + REDISPASSWORD.
# REDIS_ENABLED=false
# CACHE_API_ENABLED=true
# CACHE_TTL_SECONDS=300
# CACHE_MAX_BODY_BYTES=5242880
# CACHE_KEY_PREFIX=cache

# ─── Platform super-admin (Orbit / organization-manager) ───────────────────
# PLATFORM_ADMIN_EMAIL=admin@xtrawrkx.com
# PLATFORM_ADMIN_PASSWORD=XtrawrkxAdmin@2025
# PLATFORM_ADMIN_RESET_PASSWORD=true
